    { "part": "cell-root",  "element": "button", "notes": "Individual tab trigger; paddingX 12px, paddingY 6px, cornerRadius 8px; active state adds bg/brand-low fill + drop-shadow" },
    { "part": "cell-label", "element": "span",   "notes": "Tab label text; bold weight in active state, regular in rest" },
    { "part": "cell-badge", "element": "span",   "notes": "Numeric count pill; bg/brand-low + fg/brand-contrasted when active; transparent + fg/muted when rest" }
  ],
  "variantAxes": {
