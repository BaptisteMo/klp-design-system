{
  "name": "text-area",
  "displayName": "Text Area",
  "figmaNode": "115177:2608",
  "captureBrand": "wireframe",
  "category": "inputs",
  "description": "Multi-line text input with optional rich-text formatting toolbar. Two feature variants: Simple (plain textarea) and Rich text (with formatting toolbar and action bar). Supports Default, Focus, Filled, Danger, Success, and Disable states.",
  "radixPrimitive": "@radix-ui/react-slot",
  "anatomy": [
    { "part": "root",        "element": "div",      "notes": "Vertical flex wrapper; gap driven by Sizing/M token" },
    { "part": "head",        "element": "div",      "notes": "Header row: label + optional info icon; gap Sizing/XS" },
    { "part": "label",       "element": "label",    "notes": "Field label text; hidden when showHeader=false" },
    { "part": "info-icon",   "element": "span",     "notes": "Info icon instance (lucide info); hidden when showInfoIcon=false" },
    { "part": "input",       "element": "div",      "notes": "Main textarea container; fill, stroke and shadow change per state" },
    { "part": "toolbar",     "element": "div",      "notes": "Rich text formatting row (Frame 1); only rendered for feature=rich-text" },
    { "part": "placeholder", "element": "span",     "notes": "Placeholder/text content layer inside the input area" },
    { "part": "action-bar",  "element": "div",      "notes": "Bottom confirm/cancel action row (Frame 2); only rendered for feature=rich-text" }
  ],
  "variantAxes": {
    "feature": ["rich-text", "simple"],
    "state": ["default", "focus", "filled", "danger", "success", "disable"]
  },
