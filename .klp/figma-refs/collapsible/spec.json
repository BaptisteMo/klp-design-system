  "description": "Expandable disclosure panel with a header (icon + title + chevron toggle button) and a collapsible content area. Single variant axis: open/close state.",
  "radixPrimitive": "@radix-ui/react-collapsible",
  "anatomy": [
    {
      "part": "root",
      "element": "div",
      "notes": "Outer card wrapper. cornerRadius differs per state: 8px (close), 16px (open). Both bind fill/stroke to cross-file variables resolving to bg/default and bd/default."
    },
    {
      "part": "header",
      "element": "div",
      "notes": "Trigger row with icon, title and toggle button. In the open variant the header has a frosted-glass fill (bg/inset at 70% opacity + backdrop-blur). In the close variant the header is the root itself — no separate header frame."
    },
    {
      "part": "icon",
      "element": "span",
      "notes": "Leading icon in the header. Currently a shopping-cart placeholder; consumer replaces via prop. Lucide icon wrapper at 20px size."
    },
    {
      "part": "title",
      "element": "span",
      "notes": "Section title text (semibold, text-large)."
    },
    {
      "part": "toggle-button",
      "element": "button",
      "notes": "Tertiary icon button containing a chevron-down icon. Triggers open/close.",
      "klpComponent": "button",
      "klpComponentProps": { "variant": "tertiary", "size": "icon" },
      "figmaInstance": { "name": "Button/Tertiary/Icon/Rest", "key": "8a719f67643fddf515a583ffc43b6d90988774d2" }
    },
    {
      "part": "content",
      "element": "div",
      "notes": "Revealed content area. Hidden when state=close. padding 24px, gap 16px, cornerRadius 12px (literal)."
    },
    {
      "part": "content-text",
      "element": "p",
      "notes": "Placeholder body text slot inside the content area. Consumer replaces with arbitrary children."
    }
  ],
