{
  "name": "table-cells-actions",
  "displayName": "Table Cells / Actions",
  "figmaNode": "115189:57821",
  "captureBrand": "wireframe",
  "category": "table cells",
  "description": "A table cell that renders 1–4 action buttons inline. Icon-only buttons use bg/invisible; the last/primary action button uses bg/inset with a label and optional chevron icon.",
  "radixPrimitive": null,
  "composition": {
    "note": "This component is a pure composition of Button instances. It contains no novel visual primitives beyond layout and spacing tokens.",
    "uses": [
      {
        "klpComponent": "button",
        "registered": true,
        "figmaInstanceLayers": [
          "button-1",
          "button-2",
          "button-3",
          "button-primary"
        ],
        "notes": "Icon-only buttons (button-1 to button-3) use Size=Icon variant with bg/invisible fill. The last button (button-primary) uses a labelled variant with bg/inset fill."
      }
    ]
  },
  "anatomy": [
    {
      "part": "root",
      "element": "div",
      "notes": "Horizontal flex container, all padding and gap bound to Sizing tokens. Width is fixed (256px at height=2/actions=4) and shrinks per variant."
    },
    {
      "part": "button-1",
      "element": "INSTANCE:Button",
      "notes": "First icon-only action button. bg/invisible fill. Visible when Actions >= 1 in icon-only rows, or when Actions >= 2+ (secondary slots)."
    },
    {
      "part": "button-2",
      "element": "INSTANCE:Button",
      "notes": "Second icon-only action button. bg/invisible fill. Visible when Actions >= 2."
    },
    {
      "part": "button-3",
      "element": "INSTANCE:Button",
      "notes": "Third icon-only action button. bg/invisible fill. Visible when Actions >= 3."
    },
    {
      "part": "button-primary",
      "element": "INSTANCE:Button",
      "notes": "Primary labelled action button. bg/inset fill, label text + right chevron icon. Always the last slot. Visible for all Actions counts in height=2; last slot in all variants."
    }
  ],
  "variantAxes": {
    "height": ["1", "2"],
    "actions": ["1", "2", "3", "4"]
  },
