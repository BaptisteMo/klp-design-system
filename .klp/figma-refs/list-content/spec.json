{
  "name": "list-content",
  "displayName": "List Content",
  "figmaNode": "115177:6964",
  "captureBrand": "wireframe",
  "category": "list",
  "description": "A list row with a decorative icon on the left, label + sublabel text block, and an optional tertiary icon-button action on the right. Three sizes (Small, Medium, Large) and three interaction states (Default, Hover, Active).",
  "radixPrimitive": "@radix-ui/react-slot",
  "anatomy": [
    { "part": "root",            "element": "div",    "notes": "Vertical layout container. Padding and item-spacing vary by size. Fill changes on hover/active states." },
    { "part": "content",         "element": "div",    "notes": "Horizontal row: left-part + action-button. Always fills root width." },
    { "part": "left-part",       "element": "div",    "notes": "Horizontal: decorative-icon + headline-subcontent. Fills content width." },
    { "part": "decorative-icon", "element": "span",   "notes": "Icon wrapper. Fixed 20x20. Icon slot defaults to plus, swappable via prop. Uses fg/default stroke." },
    { "part": "label",           "element": "span",   "notes": "Primary text. fg/default color. Font: Family/Label, Weight/Label, Text/Medium size. Changes to fg/secondary-brand-contrasted on active." },
    { "part": "sublabel",        "element": "span",   "notes": "Secondary text. fg/muted color. Font: Family/Label, Weight/Label, Text/Small size (Medium size) or Text/Medium size (Large size). Toggleable via prop." },
    { "part": "action-button",   "element": "button", "notes": "Tertiary icon-only button (36x36). bg/invisible fill + bd/invisible border. Shows more-vertical icon. Toggleable via prop." }
  ],
  "variantAxes": {
    "size":  ["small", "medium", "large"],
    "state": ["default", "hover", "active"]
  },
