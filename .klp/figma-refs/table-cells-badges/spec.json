{
  "name": "table-cells-badges",
  "displayName": "Table Cells / Badges",
  "figmaNode": "115189:57723",
  "captureBrand": "klub",
  "category": "table cells",
  "description": "A table cell container that embeds a klp Badge (or Status-badge) instance. Two display types: 'badge' (text pill with branded border/fill) and 'status' (icon-only pill with semantic info styling). Two height modes (1 = single row / hug; 2 = double row / extra padding) and six width presets (100, 150-auto, 200, 300, 400, square).",
  "radixPrimitive": null,
  "anatomy": [
    {
      "part": "root",
      "element": "td",
      "notes": "Cell outer container. Padding and min-height differ between height=1 and height=2. Width is controlled by column layout, not inline style."
    },
    {
      "part": "badge-instance",
      "element": "span",
      "notes": "INSTANCE of klp badges component. For type=badge: bg/brand-low fill + bd/brand-emphasis stroke + fg/brand-contrasted text. For type=status: bg/info fill + bd/invisible stroke + fg/info icon."
    },
    {
      "part": "badge-label",
      "element": "span",
      "notes": "Text node inside the badge-instance. Visible in type=badge only."
    },
    {
      "part": "badge-icon",
      "element": "span",
      "notes": "Icon selector node inside the badge-instance. Visible in type=status only. Icon: hourglass (lucide: 'hourglass')."
    }
  ],
  "variantAxes": {
    "type": ["badge", "status"],
    "height": ["1", "2"],
    "width": ["100", "150-auto", "200", "300", "400", "square"]
  },
  "composition": {
    "reuses": [
      {
        "klpComponent": "badges",
        "notes": "Each cell contains one INSTANCE of the 'badges' klp component. For type=badge it uses the primary bordered style (bg/brand-low + bd/brand-emphasis + fg/brand-contrasted label). For type=status it uses the info light style (bg/info + bd/invisible + fg/info icon)."
      }
    ],
    "gaps": []
  },
