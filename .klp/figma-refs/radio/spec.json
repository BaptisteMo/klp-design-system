{
  "name": "radio",
  "displayName": "Radio",
  "figmaNode": "35:1616",
  "captureBrand": "klub",
  "category": "inputs",
  "description": "Radio button control with four interaction states: rest (unchecked default), hover (unchecked hovered), clicked (checked/selected), and disable. No size axis — single size only.",
  "radixPrimitive": "@radix-ui/react-radio-group",
  "anatomy": [
    {
      "part": "root",
      "element": "button",
      "notes": "Outer circular container. Uses Radix RadioGroup.Item. cornerRadius is always full (Sizing/Round = 9999px). Padding changes between unchecked (3XS=4px) and checked (2XS=6px) states."
    },
    {
      "part": "indicator",
      "element": "span",
      "notes": "Inner ellipse dot. Visible in all states but transparent/same-fill as root when unchecked. In clicked state shows white dot (bg/default) at 12px; in other states shows root bg color at 16px (invisible)."
    }
  ],
  "variantAxes": {
    "state": ["rest", "hover", "clicked", "disable"]
  },
  "variants": [
