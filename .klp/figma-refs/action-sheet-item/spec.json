{
  "name": "action-sheet-item",
  "displayName": "ActionSheet Item",
  "figmaNode": "115177:25061",
  "captureBrand": "wireframe",
  "category": "overlays",
  "description": "A single row item for action sheets. Supports icon slots on both sides, an optional description label, and seven semantic states (Default, Hover, Active, Emphased, Disabled, Destructive, Creation) across three sizes.",
  "radixPrimitive": "@radix-ui/react-slot",
  "anatomy": [
    { "part": "root",       "element": "button", "notes": "Full-width horizontal layout; fill=FIXED, counter=HUG. Uses Slot when asChild." },
    { "part": "icon-left",  "element": "span",   "notes": "Icon selector instance; 20x20px container wrapping a 16x16px lucide icon. Optional via firstIcon prop." },
    { "part": "content",    "element": "span",   "notes": "Vertical flex column filling remaining width; contains label and optional description." },
    { "part": "label",      "element": "span",   "notes": "Primary action text. fontFamily=Family/Label, fontSize=Sizing/Text/Medium." },
    { "part": "icon-right", "element": "span",   "notes": "Second action icon selector instance; 20x20px. Optional via secondAction prop." }
  ],
  "variantAxes": {
    "state": ["default", "hover", "active", "emphased", "disabled", "destructive", "creation"],
    "size":  ["lg", "md", "sm"]
  },
