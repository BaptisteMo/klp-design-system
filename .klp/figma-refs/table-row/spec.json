{
  "name": "table-row",
  "displayName": "Table Row",
  "figmaNode": "115177:22885",
  "captureBrand": "klub",
  "category": "data-display",
  "description": "A data table row component supporting default, hover, floating-action, and empty states. Contains a checkbox cell, one or more text/badge cells, and an actions cell with icon buttons.",
  "radixPrimitive": null,
  "anatomy": [
    { "part": "root",            "element": "tr",   "notes": "Row container; horizontal layout, fixed height bound to Sizing/3XL. Bottom border via stroke. No fill on default; bg/subtle fill on hover/floating-action-on." },
    { "part": "cell-checkbox",   "element": "td",   "notes": "Leftmost cell — renders a checkbox instance (table_cells/checkbox). Hidden in Empty variant." },
    { "part": "cell-left",       "element": "td",   "notes": "Frame containing badge cell and multiple text cells (table_cells/badges, table_cells/text ×N). Hidden in Empty variant." },
    { "part": "cell-badge",      "element": "span", "notes": "Badge instance inside cell-left. bg/info fill, bd/invisible stroke, fg/info icon color." },
    { "part": "cell-text",       "element": "td",   "notes": "Repeating text cell inside cell-left. Primary text uses Weight/Body Bold + fg/default; secondary text uses Weight/Body + fg/muted." },
    { "part": "cell-actions",    "element": "td",   "notes": "Rightmost cell with action icon buttons. Padding and spacing bound to Sizing/XS. Has bg/subtle fill when floating-action is ON." },
    { "part": "action-button",   "element": "button", "notes": "Icon-only button inside cell-actions. bg/invisible fill, bd/invisible stroke, Radius/L corner, icons use fg/muted color." },
    { "part": "empty-message",   "element": "td",   "notes": "Text label visible only in Empty variant. Literal black fill (token gap — expected --klp-fg-default)." },
    { "part": "empty-illustration", "element": "div", "notes": "Illustration frame visible only in Empty variant (undraw SVG asset, no token bindings)." }
  ],
  "variantAxes": {
    "type": ["default", "default-hover", "floating-action", "empty"],
    "floating-action": ["none", "on", "off"]
  },
