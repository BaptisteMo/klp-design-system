{
  "name": "@klp/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "KLP design system — Radix Primitives + Tailwind v4, shadcn-style copy-paste.",
  "bin": {
    "klp-ui": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "sync:tokens": "tsx scripts/sync-tokens.ts",
    "build:registry": "tsx scripts/build-registry.ts",
    "docs:generate": "echo 'Docs are generated by the documentalist agent. Dispatch it via Claude Code: operation=DOCUMENT, component=<name>. Or run: /klp-build-component <name> (Stage 4 dispatches the documentalist automatically).' && exit 1",
    "docs:validate": "echo 'Doc lint is performed by the documentalist agent. Dispatch it via Claude Code: operation=LINT.' && exit 1",
    "verify:component": "tsx scripts/verify-component.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "tailwind-merge": "^2.5.4"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
